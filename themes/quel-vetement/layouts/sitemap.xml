{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- $pages := slice -}}
{{- range .Data.Pages -}}
  {{- if and (ne .Kind "taxonomy") (not .Params.private) (not .Params.noindex) }}
    {{- $isTag := or (eq .Type "tags") (eq .Section "tags") -}}
    {{- $isRealTerm := true -}}
    {{- if eq .Kind "term" -}}
      {{- $isRealTerm = false -}}
      {{- with .File }}{{ if hasSuffix .LogicalName "_index.md" }}{{ $isRealTerm = true }}{{ end }}{{ end -}}
    {{- end -}}
    {{- if and (not $isTag) $isRealTerm }}{{ $pages = $pages | append . }}{{ end -}}
  {{- end -}}
{{- end -}}
{{- range $pages }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <lastmod>{{ if not .Lastmod.IsZero }}{{ .Lastmod.Format "2006-01-02" }}{{ else }}{{ now.Format "2006-01-02" }}{{ end }}</lastmod>
    {{- $cf := "monthly" -}}{{- $pr := "0.5" -}}
    {{- if eq .Kind "home" }}{{ $cf = "weekly" }}{{ $pr = "1.0" }}{{ end -}}
    {{- if and (eq .Kind "section") (eq .Section "blog") }}{{ $cf = "daily" }}{{ $pr = "0.9" }}{{ end -}}
    {{- if and (eq .Kind "page") (eq .Section "blog") }}{{ $cf = "weekly" }}{{ $pr = "0.8" }}{{ end -}}
    {{- if eq .Section "categories" }}{{ $cf = "weekly" }}{{ $pr = "0.7" }}{{ end -}}
    <changefreq>{{ $cf }}</changefreq>
    <priority>{{ $pr }}</priority>
  </url>
{{- end }}
</urlset>
