{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- range .Data.Pages -}}
  {{- $isTag := or (eq .Type "tags") (eq .Section "tags") -}}
  {{- if and (ne .Kind "taxonomy") (not $isTag) (not .Params.private) (not .Params.noindex) }}
    {{- $ok := true -}}
    {{- if eq .Kind "term" -}}{{- $ok = false -}}{{- with .File }}{{ if hasSuffix .LogicalName "_index.md" }}{{ $ok = true }}{{ end }}{{ end -}}{{- end }}
    {{- if $ok }}
  <url><loc>{{ .Permalink }}</loc><lastmod>{{ if not .Lastmod.IsZero }}{{ .Lastmod.Format "2006-01-02" }}{{ else }}{{ now.Format "2006-01-02" }}{{ end }}</lastmod></url>
    {{- end }}
  {{- end -}}
{{- end }}
</urlset>
